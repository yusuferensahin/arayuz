/* =======================================================
   ERGENEKON HSS - YEŞİL TEMA (SADECE RENKLER DEĞİŞTİ)
======================================================== */

/* Ana Pencere ve Genel Fontlar */
QMainWindow {
    background-color: #050505; /* Siyah arka plan */
}
QWidget {
    font-family: 'Arial'; /* Orijinal font korundu */
    font-weight: bold;
}

/* =======================================================
   PANEL VE AYIRICI ÇİZGİLER
======================================================== */
QFrame#panelSag {
    border-left: 2px solid #008000; /* Koyu yeşil çizgi */
    padding-left: 5px;
}
QFrame#ayiriciCizgi {
    color: #008000;
}

/* =======================================================
   DİNAMİK LED GÖSTERGELERİ
======================================================== */
QLabel[ledDurum="aktif"] {
    background-color: #00FF00; /* Neon Yeşil */
    border-radius: 10px; /* Yuvarlaklık korundu */
    min-width: 20px; min-height: 20px;
    max-width: 20px; max-height: 20px;
}
QLabel[ledDurum="pasif"] {
    background-color: #FF0000; /* Kırmızı */
    border-radius: 10px;
    min-width: 20px; min-height: 20px;
    max-width: 20px; max-height: 20px;
}

/* Etiketler (Yazılar) */
QLabel { color: #00FF00; }
QLabel#lblCalismaModu {
    font-size: 18px;
    border: 1px solid #008000;
    padding: 8px;
    border-radius: 4px; /* Yuvarlaklık korundu */
}

/* =======================================================
   KAMERA AKIŞI DİNAMİK DURUMLARI (Hazır / E-STOP)
======================================================== */
QLabel#lblKameraFeed[kameraDurum="hazir"], QLabel#lblKameraFeed {
    border: 1px solid #008000;
    background-color: #000000;
    color: #00FF00;
    font-size: 24px;
    border-radius: 8px; /* Yuvarlaklık korundu */
}
QLabel#lblKameraFeed[kameraDurum="estop"] {
    border: 5px solid #FF0000;
    background-color: #330000;
    color: #FF3333;
    font-size: 40px;
    font-weight: bold;
    border-radius: 8px;
}

QLabel#lblSicaklikDeger { font-size: 16px; color: #00FF00; }

/* Grup Kutuları (Çerçeveler) */
QGroupBox {
    color: #00FF00;
    border: 1px solid #008000;
    margin-top: 10px;
    border-radius: 6px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px 0 5px;
}

/* =======================================================
   BUTONLAR (Hafif Yuvarlak Hatlı Modern Tasarım KORUNDU)
======================================================== */
QPushButton {
    background-color: #001A00; /* Koyu yeşil arka plan */
    color: #00FF00;
    border: 1px solid #00FF00;
    padding: 8px;
    border-radius: 6px; /* Yuvarlaklık korundu */
}
QPushButton:hover { background-color: #003300; }
QPushButton:disabled {
    background-color: #111111;
    color: #555555;
    border: 1px solid #333333;
}

/* Özel Butonlar */
QPushButton#btnAtes {
    background-color: #003300;
    color: #00FF00;
    border: 3px solid #00FF00;
    font-size: 16px;
    padding: 15px;
    border-radius: 10px; /* Yuvarlaklık korundu */
}
QPushButton#btnAcilDurdur {
    background-color: #330000;
    color: #FF3333;
    border: 3px solid #FF0000;
    font-size: 18px;
    font-weight: 900;
    border-radius: 10px;
}
QPushButton#btnAcilDurdur:hover { background-color: #660000; }
QPushButton#btnYasakliToggle {
    background-color: #001A00;
    border: 1px dashed #00FF00;
}
QPushButton#btnYasakliToggle:hover { background-color: #003300; }

/* Log Paneli ve Metin Kutuları */
QTextEdit {
    background-color: #000000;
    color: #00FF00;
    border: 1px solid #008000;
    font-size: 14px;
    border-radius: 6px;
    padding: 5px;
}
QLineEdit {
    background-color: #000000;
    color: #00FF00;
    border: 1px solid #00FF00;
    padding: 3px;
    border-radius: 4px;
}

/* Radyo Butonları */
QRadioButton { color: #00FF00; }
QRadioButton::indicator {
    width: 15px;
    height: 15px;
    border-radius: 7px;
    border: 1px solid #00FF00;
    background-color: #050505;
}
QRadioButton::indicator:checked {
    background-color: #00BFFF; /* Fotoğraftaki mavi detay korundu */
}

/* =======================================================
   ÖZEL MODERN SCROLLBAR (KAYDIRMA ÇUBUĞU) KORUNDU
======================================================== */
QScrollBar:vertical {
    border: none;
    background: #050505;
    width: 10px;
    margin: 4px 0 4px 0;
    border-radius: 5px;
}
QScrollBar::handle:vertical {
    background: #008000;
    min-height: 30px;
    border-radius: 5px;
}
QScrollBar::handle:vertical:hover {
    background: #00FF00;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
    background: none;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}